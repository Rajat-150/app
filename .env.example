# Copy this to `.env` next to docker-compose.yml on your VPS.

# Public URL the frontend uses to reach the backend.
# On a VPS behind a reverse proxy set to e.g. https://studio.yourdomain.com/api-host
REACT_APP_BACKEND_URL=http://localhost:8001

# Airtable
AIRTABLE_API_KEY=pat_replace_me
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_NAME=Scenes
AIRTABLE_FIELD_IMAGE_PROMPT=Image Prompt
AIRTABLE_FIELD_VIDEO_PROMPT=Video Prompt
AIRTABLE_FIELD_SCENE_NUMBER=Scene Number

# n8n
N8N_BASE_URL=https://n8n.yourdomain.com
N8N_WEBHOOK_SECRET=change-me-please
